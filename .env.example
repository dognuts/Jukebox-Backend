# Server
PORT=8080
ENV=development

# PostgreSQL
DATABASE_URL=postgres://jukebox:jukebox@localhost:5432/jukebox?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379/0

# Session
SESSION_TTL_HOURS=24

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# JWT
JWT_SECRET=change-me-to-a-random-64-char-string

# Resend (email delivery)
# Sign up at https://resend.com and get an API key
RESEND_API_KEY=re_xxxxxxxxxxxx
FROM_EMAIL=noreply@yourdomain.com

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:3000

# YouTube Data API v3 (for admin bulk track search on /admin/autoplay)
# Get a key at https://console.cloud.google.com → APIs & Services → Credentials
# Leave blank to disable Bulk mode; URL-paste mode keeps working either way.
YOUTUBE_DATA_API_KEY=
